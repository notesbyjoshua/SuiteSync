---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<main class="admin-shell" data-admin-root data-supabase-url={supabaseUrl} data-supabase-key={supabaseKey}>
  <header class="admin-header">
    <div><span class="survey-kicker">SUITESYNC OPERATIONS</span><h1>Matching overview</h1><p>Supervise survey responses and build balanced suites.</p></div>
    <a href={import.meta.env.BASE_URL}>← Back to site</a>
  </header>

  <section class="auth-card" data-admin-auth>
    <div class="auth-icon">✦</div><span class="step-label">ADMIN ACCESS</span><h2>Sign in to continue.</h2>
    <p>Use an approved administrator account. For access help, contact global.scholars@yale.edu.</p>
    <form data-admin-auth-form>
      <label class="field"><span>Admin email</span><input name="email" type="email" required autocomplete="email" placeholder="admin@example.com" /></label>
      <label class="field"><span>Password</span><input name="password" type="password" required minlength="8" maxlength="72" autocomplete="current-password" placeholder="Your SuiteSync password" /></label>
      <button class="button primary auth-button" type="submit">Sign in <span>→</span></button>
    </form>
    <div class="auth-message" data-admin-message role="status" hidden></div>
    <div class="demo-login">
      <span>Quick demo access</span>
      <div><input type="password" data-demo-password placeholder="Demo password" /><button type="button" data-enter-demo>Enter demo</button></div>
      <small>Shared demo access uses real Supabase data and actions.</small>
    </div>
  </section>

  <section data-admin-denied hidden class="access-denied">
    <strong>Admin access required</strong><p>You are signed in, but this account is not on the SuiteSync administrator list.</p><button class="button secondary" data-admin-signout>Sign out</button>
  </section>

  <div data-admin-dashboard hidden>
    <div class="testing-banner admin-demo-banner" data-admin-demo-banner hidden><strong>Shared demo access</strong><span>Changes on this screen affect real Supabase data.</span></div>
    <div class="admin-toolbar"><span>Signed in as <strong data-admin-email></strong></span><button data-admin-signout>Sign out</button></div>
    <section class="stat-grid">
      <article><span>Total responses</span><strong data-stat="total">—</strong></article>
      <article><span>Awaiting match</span><strong data-stat="pending">—</strong></article>
      <article><span>Matched</span><strong data-stat="matched">—</strong></article>
      <article><span>Draft suites</span><strong data-stat="suites">—</strong></article>
    </section>

    <section class="admin-panel matching-controls">
      <div class="panel-heading"><div><span class="step-label">MATCHING ALGORITHM</span><h2>Start or schedule matching</h2></div></div>
      <p class="admin-helper">Manual runs use greedy assignment followed by local-search swaps. Results update draft suite assignments for staff review and are never released automatically.</p>
      <div class="matching-action-grid">
        <article>
          <h3>Run manually</h3>
          <p>Start a matching run immediately using the responses available now.</p>
          <button class="button primary" type="button" data-start-matching>Start matching now</button>
        </article>
        <form data-schedule-matching>
          <h3>Schedule a run</h3>
          <p>Choose the date and time when matching should become ready to run.</p>
          <label class="field"><span>Start date and time</span><input type="datetime-local" name="scheduled_for" required /></label>
          <button class="button secondary" type="submit">Schedule matching</button>
        </form>
      </div>
      <div class="run-history" data-run-history></div>
    </section>

    <section class="admin-panel">
      <div class="panel-heading"><div><span class="step-label">ACCOUNTS</span><h2>Create applicant accounts</h2></div></div>
      <form class="create-suite-form create-account-form" data-create-account>
        <label class="field"><span>Applicant email</span><input name="email" type="email" required autocomplete="off" placeholder="applicant@example.com" /></label>
        <label class="field"><span>Temporary password</span><input name="password" type="password" required minlength="8" maxlength="72" autocomplete="new-password" placeholder="At least 8 characters" /></label>
        <button class="button primary" type="submit">Create account</button>
      </form>
      <p class="admin-helper">Give the password to the applicant securely. Their email is marked confirmed, so no email link is sent.</p>
    </section>

    <section class="admin-panel">
      <div class="panel-heading"><div><span class="step-label">SUITES</span><h2>Create and monitor suites</h2></div></div>
      <form class="create-suite-form" data-create-suite>
        <label class="field"><span>Suite name</span><input name="name" required maxlength="80" placeholder="e.g. Davenport 201" /></label>
        <label class="field"><span>Session</span><select name="session" required><option value="">Select</option><option value="Session I">Session I</option><option value="Session II">Session II</option><option value="Session III">Session III</option></select></label>
        <label class="field"><span>Floor</span><select name="floor" required><option value="">Select</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option></select></label>
        <label class="field"><span>Campus / college</span><select name="college" required><option value="">Select a college</option><option value="pauli_murray">Pauli Murray</option><option value="benjamin_franklin">Benjamin Franklin</option></select></label>
        <label class="field"><span>Single rooms</span><input name="single_rooms" type="number" min="0" max="6" value="2" required /></label>
        <label class="field"><span>Double rooms</span><input name="double_rooms" type="number" min="0" max="3" value="2" required /></label>
        <button class="button primary" type="submit">Create suite</button>
      </form>
      <div class="suite-grid" data-suite-grid></div>
    </section>

    <section class="admin-panel">
      <div class="panel-heading"><div><span class="step-label">APPLICANTS</span><h2>Survey responses</h2></div><label>Show <select data-response-filter><option value="all">All responses</option><option value="pending">Awaiting match</option><option value="matched">Matched</option></select></label></div>
      <div class="admin-message" data-dashboard-message hidden></div>
      <div class="response-table-wrap"><table class="response-table"><thead><tr><th>Applicant</th><th>Session</th><th>Preferences</th><th>Status</th><th>Suite assignment</th></tr></thead><tbody data-response-list></tbody></table></div>
    </section>
  </div>
</main>

<script>
  import { createClient, type User } from '@supabase/supabase-js';
  type Suite = { id: string; name: string; session: string | null; floor: number | null; college: string | null; single_rooms: number | null; double_rooms: number | null; capacity: number; status: string; suite_members: { count: number }[] };
  type Response = { id: string; preferred_name: string; email: string; track: string | null; session: string; extroversion: number | null; organization: number | null; room_type: string | null; bedtime_preference: string | null; preferred_suitemates: number | null; floor_preference: string | null; college_preference: string | null; sound_level: number | null; submitted_at: string; matching_status: string; suite_id: string | null };
  type MatchingRun = { id: string; status: string; trigger_type: string; scheduled_for: string | null; started_at: string | null; created_at: string };

  const root = document.querySelector('[data-admin-root]');
  if (root instanceof HTMLElement) {
    const url = root.dataset.supabaseUrl;
    const key = root.dataset.supabaseKey;
    const client = url && key ? createClient(url, key) : null;
    let suites: Suite[] = [];
    let responses: Response[] = [];
    let matchingRuns: MatchingRun[] = [];
    let demoMode = false;
    let demoPassword = '';

    const callDemoAdmin = async (action: string, values: Record<string, unknown> = {}) => {
      if (!client) throw new Error('Supabase is not configured');
      const { data, error } = await client.functions.invoke('demo-admin', { body: { action, password: demoPassword, ...values } });
      if (error || data?.error) throw new Error(data?.error || error?.message || 'Demo admin request failed');
      return data;
    };

    const refreshDemoDashboard = async () => {
      const data = await callDemoAdmin('load');
      suites = (data.suites ?? []) as Suite[];
      responses = (data.responses ?? []) as Response[];
      matchingRuns = (data.runs ?? []) as MatchingRun[];
      render();
    };

    const loadDemoDashboard = async (password: string) => {
      demoMode = true;
      demoPassword = password;
      await refreshDemoDashboard();
      setScreen('dashboard');
      root.querySelectorAll('[data-admin-email]').forEach(el => { el.textContent = 'shared demo administrator'; });
      const banner = root.querySelector('[data-admin-demo-banner]'); if (banner instanceof HTMLElement) banner.hidden = false;
    };

    const escapeHtml = (value: unknown) => String(value ?? '').replace(/[&<>'"]/g, character => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
    })[character] ?? character);
    const formatSubmittedAt = (value: string) => new Intl.DateTimeFormat(undefined, {
      dateStyle: 'medium', timeStyle: 'short'
    }).format(new Date(value));

    const message = (copy: string, kind = 'error') => {
      const el = root.querySelector('[data-dashboard-message]');
      if (el instanceof HTMLElement) { el.textContent = copy; el.dataset.kind = kind; el.hidden = !copy; }
    };

    const setScreen = (screen: 'auth' | 'denied' | 'dashboard') => {
      const mapping = { auth: '[data-admin-auth]', denied: '[data-admin-denied]', dashboard: '[data-admin-dashboard]' };
      Object.entries(mapping).forEach(([name, selector]) => { const el = root.querySelector(selector); if (el instanceof HTMLElement) el.hidden = name !== screen; });
    };

    const render = () => {
      const stats = { total: responses.length, pending: responses.filter(r => r.matching_status === 'pending').length, matched: responses.filter(r => r.matching_status === 'matched').length, suites: suites.length };
      Object.entries(stats).forEach(([name, value]) => { const el = root.querySelector(`[data-stat="${name}"]`); if (el) el.textContent = String(value); });
      const suiteGrid = root.querySelector('[data-suite-grid]');
      if (suiteGrid) suiteGrid.innerHTML = suites.length ? suites.map(s => `<article><span>${escapeHtml(s.session || 'All sessions')}</span><h3>${escapeHtml(s.name)}</h3><small>${escapeHtml(s.college === 'pauli_murray' ? 'Pauli Murray' : s.college === 'benjamin_franklin' ? 'Benjamin Franklin' : 'College not set')} · ${s.floor ? `Floor ${s.floor}` : 'Floor not set'}</small><small>${s.single_rooms ?? '—'} single rooms · ${s.double_rooms ?? '—'} double rooms</small><strong>${s.suite_members?.[0]?.count ?? 0} / ${s.capacity} members</strong><div><i style="width:${((s.suite_members?.[0]?.count ?? 0) / s.capacity) * 100}%"></i></div></article>`).join('') : '<p class="empty-state">No suites created yet.</p>';
      renderResponses();
      const history = root.querySelector('[data-run-history]');
      if (history) history.innerHTML = matchingRuns.length ? `<h3>Recent runs</h3>${matchingRuns.map(run => `<div><span class="status-badge ${escapeHtml(run.status)}">${escapeHtml(run.status.replaceAll('_', ' '))}</span><strong>${escapeHtml(run.trigger_type === 'manual' ? 'Manual run' : 'Scheduled run')}</strong><small>${escapeHtml(formatSubmittedAt(run.scheduled_for || run.started_at || run.created_at))}</small></div>`).join('')}` : '<p class="empty-state">No matching runs have been created yet.</p>';
    };

    const renderResponses = () => {
      const filter = root.querySelector('[data-response-filter]');
      const value = filter instanceof HTMLSelectElement ? filter.value : 'all';
      const shown = value === 'all' ? responses : responses.filter(r => r.matching_status === value);
      const list = root.querySelector('[data-response-list]');
      if (!list) return;
      list.innerHTML = shown.length ? shown.map(r => `<tr><td><strong>${escapeHtml(r.preferred_name)}</strong><small>${escapeHtml(r.email)}</small><small>Submitted ${escapeHtml(formatSubmittedAt(r.submitted_at))}</small></td><td><strong>${escapeHtml(r.session)}</strong><small>${escapeHtml(r.track || 'Legacy response')}</small></td><td><small>Extroversion ${r.extroversion ?? '—'}/5 · Organization ${r.organization ?? '—'}/5 · Sound ${r.sound_level ?? '—'}/5</small><span>${escapeHtml(r.room_type || '—')} · ${escapeHtml(r.bedtime_preference || '—')} · ${r.preferred_suitemates ?? '—'} suitemates</span><small>${escapeHtml(r.floor_preference || '—')} floor · ${escapeHtml(r.college_preference || '—')}</small></td><td><span class="status-badge ${escapeHtml(r.matching_status)}">${escapeHtml(r.matching_status)}</span></td><td><div class="assignment-control"><select data-assign="${r.id}"><option value="">Unassigned</option>${suites.map(s => `<option value="${s.id}" ${r.suite_id === s.id ? 'selected' : ''}>${escapeHtml(s.name)}</option>`).join('')}</select><button data-save-assignment="${r.id}">Save</button></div></td></tr>`).join('') : '<tr><td colspan="5" class="empty-state">No responses match this view.</td></tr>';
    };

    const loadDashboard = async (user: User) => {
      if (!client) return;
      const { data: allowed } = await client.rpc('is_admin');
      if (!allowed) { setScreen('denied'); return; }
      setScreen('dashboard');
      root.querySelectorAll('[data-admin-email]').forEach(el => { el.textContent = user.email ?? ''; });
      const [suiteResult, responseResult, runResult] = await Promise.all([
        client.from('suites').select('id,name,session,floor,college,single_rooms,double_rooms,capacity,status,suite_members(count)').order('name'),
        client.from('survey_responses').select('id,preferred_name,email,track,session,extroversion,organization,room_type,bedtime_preference,preferred_suitemates,floor_preference,college_preference,sound_level,submitted_at,matching_status,suite_id').order('submitted_at', { ascending: true }),
        client.from('matching_runs').select('id,status,trigger_type,scheduled_for,started_at,created_at').order('created_at', { ascending: false }).limit(10)
      ]);
      if (suiteResult.error || responseResult.error || runResult.error) { message('Could not load matching data. Check the admin database policies.'); return; }
      suites = (suiteResult.data ?? []) as Suite[];
      responses = (responseResult.data ?? []) as Response[];
      matchingRuns = (runResult.data ?? []) as MatchingRun[];
      render();
    };

    if (!client) {
      setScreen('auth');
      const el = root.querySelector('[data-admin-message]');
      if (el instanceof HTMLElement) { el.textContent = 'Supabase is not configured.'; el.dataset.kind = 'error'; el.hidden = false; }
    } else {
      client.auth.onAuthStateChange((_event, nextSession) => { if (nextSession?.user) void loadDashboard(nextSession.user); else setScreen('auth'); });
      const { data: { session } } = await client.auth.getSession();
      if (session?.user) await loadDashboard(session.user); else setScreen('auth');
    }

    root.querySelector('[data-admin-auth-form]')?.addEventListener('submit', async (event) => {
      event.preventDefault(); if (!client || !(event.currentTarget instanceof HTMLFormElement)) return;
      const data = new FormData(event.currentTarget); const email = String(data.get('email') ?? '').trim().toLowerCase(); const password = String(data.get('password') ?? '');
      const { error } = await client.auth.signInWithPassword({ email, password });
      const el = root.querySelector('[data-admin-message]');
      if (el instanceof HTMLElement) { el.textContent = error ? 'The email or password is incorrect, or this account has not been created yet.' : ''; el.dataset.kind = 'error'; el.hidden = !error; }
    });

    root.querySelector('[data-enter-demo]')?.addEventListener('click', () => {
      const input = root.querySelector('[data-demo-password]');
      const notice = root.querySelector('[data-admin-message]');
      if (!(input instanceof HTMLInputElement)) return;
      if (input.value !== 'test123') {
        if (notice instanceof HTMLElement) { notice.textContent = 'Incorrect demo password.'; notice.dataset.kind = 'error'; notice.hidden = false; }
        return;
      }
      void loadDemoDashboard(input.value).catch(error => {
        demoMode = false; demoPassword = '';
        if (notice instanceof HTMLElement) { notice.textContent = error instanceof Error ? error.message : 'Could not enter demo admin.'; notice.dataset.kind = 'error'; notice.hidden = false; }
      });
    });

    root.querySelectorAll('[data-admin-signout]').forEach(button => button.addEventListener('click', () => {
      if (demoMode) {
        demoMode = false;
        const banner = root.querySelector('[data-admin-demo-banner]'); if (banner instanceof HTMLElement) banner.hidden = true;
        setScreen('auth');
      } else void client?.auth.signOut();
    }));
    root.querySelector('[data-response-filter]')?.addEventListener('change', renderResponses);

    const refreshRuns = async () => {
      if (demoMode) { await refreshDemoDashboard(); return; }
      if (!client) return;
      const { data } = await client.from('matching_runs').select('id,status,trigger_type,scheduled_for,started_at,created_at').order('created_at', { ascending: false }).limit(10);
      matchingRuns = (data ?? []) as MatchingRun[]; render();
    };

    root.querySelector('[data-start-matching]')?.addEventListener('click', async (event) => {
      if (!(event.currentTarget instanceof HTMLButtonElement)) return;
      if (demoMode) {
        try { await callDemoAdmin('start_matching'); message('Matching run created.', 'success'); await refreshDemoDashboard(); } catch (error) { message(error instanceof Error ? error.message : 'Request failed'); } return;
      }
      if (!client) return;
      const button = event.currentTarget; button.disabled = true;
      const { error } = await client.functions.invoke('run-matching'); button.disabled = false;
      if (error) { message(error.message); return; }
      message('Matching completed. Review the proposed suite assignments below.', 'success');
      const { data: refreshedResponses } = await client.from('survey_responses').select('id,preferred_name,email,track,session,extroversion,organization,room_type,bedtime_preference,preferred_suitemates,floor_preference,college_preference,sound_level,submitted_at,matching_status,suite_id').order('submitted_at'); responses = (refreshedResponses ?? []) as Response[];
      await refreshRuns();
    });

    root.querySelector('[data-schedule-matching]')?.addEventListener('submit', async (event) => {
      event.preventDefault(); if (!(event.currentTarget instanceof HTMLFormElement)) return;
      const form = event.currentTarget; const data = new FormData(form); const localTime = String(data.get('scheduled_for') ?? '');
      const scheduledFor = new Date(localTime);
      if (Number.isNaN(scheduledFor.getTime()) || scheduledFor <= new Date()) { message('Choose a time in the future.'); return; }
      if (demoMode) {
        try { await callDemoAdmin('schedule_matching', { scheduledFor: scheduledFor.toISOString() }); form.reset(); message('Matching run scheduled.', 'success'); await refreshDemoDashboard(); } catch (error) { message(error instanceof Error ? error.message : 'Request failed'); } return;
      }
      if (!client) return;
      const { error } = await client.rpc('admin_schedule_matching', { requested_start: scheduledFor.toISOString() });
      if (error) { message(error.message); return; }
      form.reset(); message('Matching run scheduled.', 'success'); await refreshRuns();
    });

    root.querySelector('[data-create-account]')?.addEventListener('submit', async (event) => {
      event.preventDefault(); if (!(event.currentTarget instanceof HTMLFormElement)) return;
      const form = event.currentTarget; if (!form.reportValidity()) return;
      const data = new FormData(form);
      if (demoMode) { try { await callDemoAdmin('create_account', { email: String(data.get('email') ?? ''), accountPassword: String(data.get('password') ?? '') }); form.reset(); message('Applicant account created.', 'success'); } catch (error) { message(error instanceof Error ? error.message : 'Request failed'); } return; }
      if (!client) return;
      const { error } = await client.functions.invoke('admin-create-user', { body: { email: String(data.get('email') ?? '').trim().toLowerCase(), password: String(data.get('password') ?? '') } });
      if (error) { message('Could not create the account. It may already exist, or the password may not meet the project requirements.'); return; }
      form.reset(); message('Applicant account created.', 'success');
    });

    root.querySelector('[data-create-suite]')?.addEventListener('submit', async (event) => {
      event.preventDefault(); if (!(event.currentTarget instanceof HTMLFormElement)) return;
      const form = event.currentTarget; const data = new FormData(form);
      if (demoMode) {
        try { await callDemoAdmin('create_suite', { name: String(data.get('name')), session: String(data.get('session') ?? ''), floor: Number(data.get('floor')), college: String(data.get('college') ?? ''), singleRooms: Number(data.get('single_rooms')), doubleRooms: Number(data.get('double_rooms')) }); form.reset(); message('Suite created.', 'success'); await refreshDemoDashboard(); } catch (error) { message(error instanceof Error ? error.message : 'Request failed'); } return;
      }
      if (!client) return;
      const { error } = await client.rpc('admin_create_suite_with_rooms', { suite_name: String(data.get('name')), suite_session: String(data.get('session') ?? ''), suite_floor: Number(data.get('floor')), suite_college: String(data.get('college') ?? ''), suite_single_rooms: Number(data.get('single_rooms')), suite_double_rooms: Number(data.get('double_rooms')) });
      if (error) { message(error.message); return; }
      form.reset(); message('Suite created.', 'success');
      const { data: refreshed } = await client.from('suites').select('id,name,session,floor,college,single_rooms,double_rooms,capacity,status,suite_members(count)').order('name'); suites = (refreshed ?? []) as Suite[]; render();
    });

    root.querySelector('[data-response-list]')?.addEventListener('click', async (event) => {
      const target = event.target; if (!(target instanceof HTMLButtonElement) || !target.dataset.saveAssignment) return;
      const responseId = target.dataset.saveAssignment; const select = root.querySelector(`[data-assign="${responseId}"]`);
      if (!(select instanceof HTMLSelectElement)) return;
      if (demoMode) {
        try { await callDemoAdmin(select.value ? 'assign' : 'unassign', { responseId, suiteId: select.value || null }); message('Assignment saved.', 'success'); await refreshDemoDashboard(); } catch (error) { message(error instanceof Error ? error.message : 'Request failed'); } return;
      }
      if (!client) return;
      target.disabled = true;
      const result = select.value ? await client.rpc('admin_assign_response', { target_response_id: responseId, target_suite_id: select.value }) : await client.rpc('admin_unassign_response', { target_response_id: responseId });
      target.disabled = false;
      if (result.error) { message(result.error.message); return; }
      const response = responses.find(r => r.id === responseId); if (response) { response.suite_id = select.value || null; response.matching_status = select.value ? 'matched' : 'pending'; }
      const { data: refreshed } = await client.from('suites').select('id,name,session,floor,college,single_rooms,double_rooms,capacity,status,suite_members(count)').order('name'); suites = (refreshed ?? []) as Suite[]; message('Assignment saved.', 'success'); render();
    });
  }
</script>
