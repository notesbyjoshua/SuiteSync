---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="site-quick-links" aria-label="Account links">
  <a class="admin-header-link" href={`${base}/suite/`}>My Suite</a>
  <a class="admin-header-link" href={`${base}/admin/`}>Admin</a>
</nav>

<style>
  .admin-header-link {
    align-items: center;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.55rem;
    color: var(--sl-color-white);
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 700;
    height: 2rem;
    padding-inline: 0.8rem;
    text-decoration: none;
  }

  .admin-header-link:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent-high);
  }

  .site-quick-links { align-items: center; display: flex; gap: 0.45rem; }
</style>
