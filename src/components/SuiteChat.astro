---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<main class="chat-shell" data-chat-root data-supabase-url={supabaseUrl} data-supabase-key={supabaseKey}>
  <header class="chat-header"><a href={import.meta.env.BASE_URL}>← SuiteSync home</a><span class="survey-kicker">MY SUITE</span><h1>Meet your suitemates.</h1><p>Once your assignment is released, this is your private space to say hello and get ready for YYGS.</p></header>

  <div class="testing-banner chat-demo-banner"><strong>Demo suite</strong><span>This sample chat resets when the page refreshes.</span></div>

  <div class="chat-layout" data-chat-layout hidden>
    <aside class="member-panel"><span class="step-label">YOUR SUITE</span><h2 data-suite-name></h2><p data-suite-location></p><p class="room-assignment">Your room: <strong data-room-assignment>Double room · Roommate: Alex</strong></p><h3>Suitemates</h3><ul data-member-list></ul></aside>
    <section class="message-panel">
      <div class="message-heading"><div><span class="status-dot"></span><strong>Suite chat</strong></div><small>Only your suitemates can see these messages.</small></div>
      <div class="message-list" data-message-list aria-live="polite"></div>
      <form class="message-form" data-message-form><label class="sr-only" for="suite-message">Message</label><input id="suite-message" name="message" maxlength="1000" required autocomplete="off" placeholder="Write a message to your suite…" /><button type="submit">Send</button></form>
      <div class="form-error" data-chat-error hidden></div>
    </section>
  </div>
</main>

<script>
  type Member = { user_id: string | null; preferred_name: string };
  type Context = { suite: { id: string; name: string; floor: number | null; college: string | null }; members: Member[] };
  type Message = { id: string; sender_user_id: string; body: string; created_at: string };

  const root = document.querySelector('[data-chat-root]');
  if (root instanceof HTMLElement) {
    let context: Context | null = null;
    let currentUserId = '';
    let demoMessages: Message[] = [];
    const escapeHtml = (value: unknown) => String(value ?? '').replace(/[&<>'"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[c] ?? c);
    const show = (name: 'auth' | 'waiting' | 'chat') => {
      const screens = { auth: '[data-chat-auth]', waiting: '[data-chat-waiting]', chat: '[data-chat-layout]' };
      Object.entries(screens).forEach(([key, selector]) => { const el = root.querySelector(selector); if (el instanceof HTMLElement) el.hidden = key !== name; });
    };
    const renderMessages = (messages: Message[]) => {
      const list = root.querySelector('[data-message-list]'); if (!(list instanceof HTMLElement) || !context) return;
      const names = new Map(context.members.map(m => [m.user_id, m.preferred_name]));
      list.innerHTML = messages.length ? messages.map(m => `<article class="chat-message ${m.sender_user_id === currentUserId ? 'is-mine' : ''}"><div><strong>${escapeHtml(names.get(m.sender_user_id) || 'Suitemate')}</strong><time>${escapeHtml(new Date(m.created_at).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }))}</time></div><p>${escapeHtml(m.body)}</p></article>`).join('') : '<p class="empty-state">No messages yet. Be the first to say hello!</p>';
      list.scrollTop = list.scrollHeight;
    };
    const loadDemoChat = () => {
      currentUserId = 'demo-you';
      context = { suite: { id: 'demo-suite', name: 'Franklin 201', floor: 2, college: 'benjamin_franklin' }, members: [
        { user_id: 'demo-you', preferred_name: 'You' }, { user_id: 'demo-alex', preferred_name: 'Alex' }, { user_id: 'demo-samuel', preferred_name: 'Samuel' }, { user_id: 'demo-mateo', preferred_name: 'Mateo' }
      ] };
      demoMessages = [
        { id: 'demo-1', sender_user_id: 'demo-alex', body: 'Hi everyone! I’m excited to meet you for Session II 👋', created_at: new Date(Date.now() - 600000).toISOString() },
        { id: 'demo-2', sender_user_id: 'demo-samuel', body: 'Same here! I can’t wait to meet everyone at Benjamin Franklin.', created_at: new Date(Date.now() - 300000).toISOString() }
      ];
      show('chat');
      const name = root.querySelector('[data-suite-name]'); if (name) name.textContent = context.suite.name;
      const location = root.querySelector('[data-suite-location]'); if (location) location.textContent = 'Benjamin Franklin · Floor 2';
      const members = root.querySelector('[data-member-list]'); if (members) members.innerHTML = context.members.map(m => `<li><span>${escapeHtml(m.preferred_name.slice(0, 1))}</span>${escapeHtml(m.preferred_name)}</li>`).join('');
      renderMessages(demoMessages);
    };
    root.querySelector('[data-message-form]')?.addEventListener('submit', async event => { event.preventDefault(); if (!context || !(event.currentTarget instanceof HTMLFormElement)) return; const form = event.currentTarget; const data = new FormData(form); const body = String(data.get('message') ?? '').trim(); if (!body) return; demoMessages.push({ id: crypto.randomUUID(), sender_user_id: currentUserId, body, created_at: new Date().toISOString() }); renderMessages(demoMessages); form.reset(); });
    loadDemoChat();
  }
</script>
